{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "esModuleInterop": true,
    "strict": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,

    // Возвращаем baseUrl (он всё ещё нужен для работы paths в TypeScript)
    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*",
    "declarations.d.ts"
  ]
}